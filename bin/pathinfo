#h: Usage: $0 [-u][-r VARIABLE][-v VARIABLE]
#h:
#h: This script sources `/etc/pathinfo` at load.
#h:
#h:     -u          : Reload `/etc/pathinfo`.
#h:     -r VARIABLE : If the variable is not defined print a message.
#h:     -v VARIABLE : Print variable.
pathinfo() {
    ## Parse command line arguments.
    local OPTIND optopt= opt_u= opt_r= r= opt_v= v=
    while getopts "ur:v:" optopt;do # OPTARG
        case $optopt in
            u)  local opt_u="y";;
            r)  local opt_r="${opt_r} ${OPTARG}";;
            v)  local opt_v="${opt_v} ${OPTARG}";;
            \?) return 1;;
        esac
    done
    shift $(( $OPTIND - 1 ))
    ## Source pathinfo file.
    if test @"${opt_u}" = @"y" && test -f "/etc/pathinfo";then
        . "/etc/pathinfo"
    fi
    local vars=""
    for r in ${opt_r};do
        if eval 'test ! -n "${'"${r}"'}"';then
            local vars="${vars:+${vars} }${r}"
        fi
    done
    if test -n "${vars}";then
        echo "${SCRNAME}: error: Please set teh following variables in /etc/pathinfo:" >&2
        echo "${SCRNAME}: error: ${vars}"
        return 1
    fi
    for v in ${opt_v};do
        eval "printf 'pathinfo: %-20s : %s\\n' ${v} \"\${${v}}\""
    done
}

SCRNAME="`basename "$0"`"
if test -f "/etc/pathinfo";then
    . "/etc/pathinfo"
fi
if test @"${SCRNAME}" = @"pathinfo";then
    if test -n "$1";then
        pathinfo "$@"
    else
        sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|`basename $0`|g"
        echo ""
        sed -n 's/^ *#l: \{0,2\}//p' "$0"
    fi
fi
