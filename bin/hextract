#h: Usage: $0 [sudo] FILE [DIR [PATT]
#h:
#h: Extract the file to directory. [.tar][.tgz][.tar.*][.zip][.7z][.rar]
hextract() {
    ## Get options.
    if test sudo = "$1";then
        local sudo=sudo; shift
    else
        local sudo=
    fi
    local f="$1" d="${2:-`pwd`}" p="$3"
    ## Check arguments.
    if test ! -n "${f}";then
        return 1
    elif test ! -f "${f}";then
        echo "${SCRNAME}: error: File '${f}' does not exists." >&2
        return 1
    fi
    ## Create output firectory.
    ${sudo} mkdir -p "$d"
    ## Extract the file.
    case "${f}" in
        *.tar|*.tar.*|*.tgz) ${sudo} tar xf "${f}" -h -o -m -C "${d}"             ;;
        *.zip)               ${sudo} unzip -q -o "${f}" -d "${d}"                 ;;
        *.7z|*.rar)          ${sudo} 7z x -y "${f}" -o"${d}"                      ;;
        *)                   echo "${SCRNAME}: error: Unsupported file '$f'." >&2
                             return 1;;
    esac
    ## If a directory and pattern where specified.
    if test -n "${2}" && test -n "${p}";then
        local dd="`${sudo} find "${d}" -maxdepth 1 -mindepth 1 -iname ${p} | head -n 1`"
        if test ! -d "${dd}";then
            echo "${SCRNAME}: error: Directory \`${p}\` not found." >&2
            return 1
        fi
        ${sudo} mv "${dd}" "${dd}.tmp"
        env dd="${dd}" sh -c 'cd "${dd}.tmp"; tar cf - *' | ${sudo} tar xf - -C "${d}"
        ${sudo} rm -rf "${dd}.tmp"
    fi
}
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"hextract";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hextract "$@"
            ;;
    esac
fi
