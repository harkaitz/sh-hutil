#h: Usage: $0 [+-] DIRECTORY
#h:
#h: Enter and quit from a directory printing a message.
vcd() {
    if test @"$1" = @"+";then
        local o="enter"
        local d="$2"
    elif test @"$1" = @"-";then
        local o="leave"
        local d="${2:-${VCD_DIR}}"
    else
        local o="enter"
        local d="$1"
    fi
    if test ! -n "${d}";then
        echo "vcd: error: Didn't specify a directory." >&2
        return 1
    elif test @"${o}" = @"enter";then
        cd "${d}"
        echo "${SCRNAME}: Entering directory '`pwd`'"
    elif test @"${o}" = @"leave";then
        echo "${SCRNAME}: Leaving directory '`pwd`'"
        cd "${d}"    
    fi
}

VCD_DIR="`pwd`"
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"vcd";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            echo "vcd: error: Please source vcd before usage." >&2
            exit 1
            ;;
    esac
fi
