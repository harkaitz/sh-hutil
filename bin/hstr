#h: Usage: $0 ...
#h:
#h: optopt VAR[=VAL] [SEP] :
#h: optarg VAR[=VAR] [SEP] :
#h: vname STRING...        : Print variable name.
#h: fname STRING...        : Print function name.
#h: escape STRING...       : Return single quote escaped string.
#h: escape2 STRING         : Return double queote escaped string.
#h: abspath FILENAME       : Return absolute path.
#h: suffix FILENAME        : Return suffix including the dot. (.tar.gz, ...)
#h: l-has ITEM LIST...     : Check whether the item is in list.
#h: u-proto URL            : Get protocol from URL.
#h: u-{user,pass}  URL     : Get username from URL.
#h: u-{host,port}  URL     : Get password from URL.
#h: u-path         URL     : Get content from URL.
hstr() {
    local cmd="$1"
    shift
    case "${cmd}" in
        optopt)  hstr_optopt    "$@" ;;
        optarg)  hstr_optarg    "$@" ;;
        vname)   hstr_vname     "$@" ;;
        fname)   hstr_fname     "$@" ;;
        escape)  hstr_escape    "$@" ;;
        escape2) hstr_escape2   "$@" ;;
        l-has)   hstr_l_has     "$@" ;;
        ##
        u-proto) hstr_url_proto "$@" ;;
        u-user)  hstr_url_user  "$@" ;;
        u-pass)  hstr_url_pass  "$@" ;;
        u-host)  hstr_url_host  "$@" ;;
        u-port)  hstr_url_port  "$@" ;;
        u-path)  hstr_url_path  "$@" ;;
        ##
        *)       echo "${SCRNAME}: error: Invalid arguments ${cmd}." >&2
                 return 1;;
    esac
}
## -----------------------------------------------------------------------------
hstr_optopt() { local s="${2:-=}"; echo "$1" | sed -n 's|^\(-*[^'"$s"' ][^'"$s"' ]*\).*|\1|p'; }
hstr_optarg() { local s="${2:-=}"; echo "$1" | sed -n 's|^-*[^'"$s"'][^'"$s"']*'"$s"'||p'; }
hstr_vname()  { echo "$*" | sed 's|[ \.@\-]|_|g' | tr '[:lower:]' '[:upper:]'; }
hstr_fname()  { echo "$*" | sed 's|[ \.@\-]|_|g' | tr '[:upper:]' '[:lower:]'; }
hstr_escape() {
    local ret="" arg=""
    for arg in "$@";do
        local ret="$ret '`echo "$arg" | sed "s|'|'\\\\\\''|g"`'"
    done
    printf '%s\n' "$ret"
}
hstr_escape2() {
    local ret="" arg=""
    for arg in "$@";do
        local ret="$ret \"`echo "$arg" | sed 's|\([\$"]\)|\\\\\\1|g'`\""
    done
    printf '%s\n' "$ret"
}
hstr_abspath() {
    case "$1" in
        /*) echo "$1"       ;;
        *)  echo "`pwd`/$1" ;;
    esac
}
hstr_suffix() {
    local suffix="`basename "$1" | sed -n 's|.[^\.]*\.\(.*\)|\1|p'`"
    if test ! -n "$suffix";then
        echo "${SCRNAME}: error: File \`$1\` hasn't a suffix." >&2
        return 1
    fi
    echo ".$suffix"
}
hstr_l_has() {
    local item="$1" e=
    shift
    for e in "$@";do
        if test @"${item}" = @"${e}";then
            return 0
        fi
    done
    return 1
}
hstr_url_proto()    { echo "$1" | sed -n 's|^\([^:]*\)://.*|\1|p';     }
hstr_url_proto_no() { echo "$1" | sed 's|^\([^:]*\)://||';             }
hstr_url_cred()     { hstr_url_proto_no "$1" | sed -n 's|@.*||p';      }
hstr_url_user()     { hstr_url_cred "$1"     | sed    's|:.*||';       }
hstr_url_pass()     { hstr_url_cred "$1"     | sed -n 's|^[^:]*:||p';  }
hstr_url_cred_no()  { hstr_url_proto_no "$1" | sed    's|.*@||';       }
hstr_url_host()     { hstr_url_cred_no  "$1" | sed    's|[/:].*||';    }
hstr_url_port()     { hstr_url_cred_no  "$1" | sed -n 's|^[^/]*:\([0-9]*\).*|\1|p'; }
hstr_url_path()     { hstr_url_cred_no  "$1" | sed -n 's|^[^/]*/||p';  }

## -----------------------------------------------------------------------------
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"hstr";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hstr "$@"
            ;;
    esac
fi
