#h: Usage:
#h:      
#h: $0 {error,info,warning} MSG       : Print message.
#h: $0 {debug}              MSG       : Print message if $DEBUG is defined. 
#h: $0 {fatal|abort}        MSG       : Print message and fail.
#h: $0 {errif}              MSG TEST  : Print message and fail if test succedes.
#h: $0 {file}               NAME DESC : Prnt log filename.
hlog() {
    local cmd="$1"
    shift
    case "${cmd}" in
        error)
            echo "${SCRNAME}: error: $*" >&2;;
        info)
            if test -n "${HLOG_NO_PREFIX}";then
                printf '%s\n' "$*" >&2
            else
                echo "${SCRNAME}: $*" >&2
            fi;;
        warning) echo "${SCRNAME}: warn : $*" >&2;;
        debug)   if test -n "${DEBUG}";then
                     echo "${SCRNAME}: debug: $*" >&2
                 fi;;
        errif)   local m="$1"; shift
                 if "$@";then
                     hlog fatal "$m"    
                 fi;;
        fatal)   hlog error "$*"; exit 1;;
        abort)   hlog error "$*"; exit 1;;
        file)    local name="${1:-${SCRNAME}}"
                 local name="`basename "${name}"`"
                 mkdir -p "${HOME}/.log"
                 echo "${SCRNAME}: [~/.log/${name}.log] ${2}" >&2
                 echo "${HOME}/.log/${name}.log"
                 ;;
        *)       hlog info "${cmd} $*";;
    esac
}
## -----------------------------------------------------------------------------


## -----------------------------------------------------------------------------
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"hlog";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hlog "$@"
            ;;
    esac
fi
