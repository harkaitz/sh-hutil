#h: Usage: $0 ...
#h:
#h: Program checker and installer.
#h:
#h:     Distros          : @void, @centos, @ubuntu, @freebsd, @OpenBSD.
#h:     Package managers : %dpkg, %rpm, %xbps, %pacman, %pkg, %npm, %apk
#h:                        %go, %gem, %pip3
#h:
#h: Options:
#h:
#h:     -v                  : Verbose operation.
#h:     -m MSG              : Print message.
#h:     -w PROGRAM [-w ...] : Skip installation if any of the programs is
#h:                           not installed.
#h:     -q                  : Quiet mode.
#h:     -D/P                : Print distro or package manager.
#h:     -S {@D|%P} ARGS...  : Print arguments if the current system matches
#h:                           the distro (@D) or has a package manager (%P).
#h:     -i {@D|%P} PKG...   : Install packages.
#h:     -u {@D|%P} PKG...   : Remove packages.
#h:     -c {@D|%P} ...      : Check the system has one of.
#h:     -E {@D|%P} SERVICE  : Enable service.
#h:     -R {@D|%P} SERVICE  : Restart service.
#h:     -V {@D|%P} SERVICE  : Status of the service.
#h:     -O {@D|%P} SERVICE  : Shutdown service.
#h:     -X {@D|%P} SERVICE  : Disable service.
#::
if test -f /etc/profile.d/zz-go.sh;then
    . /etc/profile.d/zz-go.sh
fi
hpkg() {
    ## Parse command line options.
    local OPTIND optopt= ops= skip=
    while getopts "vDPqSiucw:m:ERVOX" optopt; do # OPTARG
        local ops="${ops}${optopt}"
        case $optopt in
            v)  local HPKG_VERBOSE=y
                ;;
            w)  if test -e "${OPTARG}"; then
                    local skip="${skip:-y}"
                elif which "${OPTARG}" >/dev/null 2>&1; then
                    local skip="${skip:-y}"
                else
                    local skip=n
                fi
                ;;
            q)  export HPKG_QUIET=y
                ;;
            m)  printf '%s: %s\n' "${SCRNAME}" "${OPTARG}"
                ;;
            \?) return 1
                ;;
        esac
    done
    shift $(( $OPTIND - 1 ))
   
    ## Operations.
    case "${ops}" in
        *D*) echo "${DISTRO_ID}"
             ;;
        *P*) echo "${PACKAGE_MANAGER}"
             ;;
        *S*) hpkg_select "$@"
             ;;
        *i*) if test ! @"${skip}" = @"y"; then
                 hpkg_install "$@" 
             fi
             ;;
        *c*) if ! hpkg_check "$@"; then
                 return 1
             fi
             ;;
        *u*) if test @"${skip}" = @"y" || test @"${skip}" = @""; then
                 hpkg_remove "$@" 
             fi
             ;;
        *E*|*R*|*V*|*O*|*X*)
            hpkg_service_"${DISTRO_ID}" "${ops}" "$@"
            ;;
    esac
}
hpkg_calc_variables() {
    export HPKG_QUIET=n
    HPKG_VERBOSE=n
    if test ! -n "${DISTRO_ID}";then
        if test -f /etc/os-release;then
            export DISTRO_ID="`sh -c '. /etc/os-release; echo "${ID}"'`"
        else
            export DISTRO_ID="`uname -s`"
        fi
    fi
    if test -n "${PACKAGE_MANAGER}"; then
        true
    elif test -f /usr/bin/apt-get; then
        export PACKAGE_MANAGER=dpkg
    elif test -f /usr/bin/yum; then
        export PACKAGE_MANAGER=rpm
    elif test -f /usr/bin/xbps-install; then
        export PACKAGE_MANAGER=xbps
    elif test -f /usr/bin/pacman; then
        export PACKAGE_MANAGER=pacman
    elif test -f /usr/sbin/pkg; then
        export PACKAGE_MANAGER=pkg
    elif test -f /sbin/apk; then
        export PACKAGE_MANAGER=apk
    else
        export PACKAGE_MANAGER=unknown
    fi
}
hpkg_error() {
    if test ! @"${HPKG_QUIET}" = @"y";then
        echo "error: $*" >&2
    fi
}
## -----------------------------------------------------------------------------
hpkg_select_var() {
    HPKG_PACKAGES= HPKG_INSTALLER="${PACKAGE_MANAGER}"
    for arg in "$@";do
        case "${arg}" in
            @${DISTRO_ID})       local found=y; continue;;
            %${PACKAGE_MANAGER}) local found=y; continue;;
            %npm)
                if which npm >/dev/null 2>&1;then
                    local found=y; HPKG_INSTALLER=npm
                    continue
                fi
                ;;
            %go)
                if which go >/dev/null 2>&1;then
                    local found=y; HPKG_INSTALLER=go
                    continue
                fi
                ;;
            %gem)
                if which gem >/dev/null 2>&1;then
                    local found=y; HPKG_INSTALLER=gem
                    continue
                fi
                ;;
            %pip3)
                if which pip3 >/dev/null 2>&1;then
                    local found=y; HPKG_INSTALLER=pip3
                    continue
                fi
                ;;
            
            @*|%*) local found=n; continue;;
            --)    continue;;
        esac
        if test @"${found}" = @"y";then
            HPKG_PACKAGES="${HPKG_PACKAGES}${arg}
"
        fi
    done
}
hpkg_select() {
    hpkg_select_var "$@"
    echo "${HPKG_PACKAGES}"
}
hpkg_install() {
    hpkg_select_var "$@"
    local pkgs="${HPKG_PACKAGES}"
    if test ! -n "${pkgs}";then
        hpkg_error "Unsupported platform: $*" >&2
        return 1
    fi
    case "${HPKG_INSTALLER}" in
        dpkg)   hpkg_vrun sudo apt-get      -y install      ${pkgs} ;;
        rpm)    hpkg_vrun sudo yum          -y install      ${pkgs} ;;
        xbps)   hpkg_vrun sudo xbps-install -Sy             ${pkgs} ;;
        pacman) hpkg_vrun sudo pacman       --noconfirm -Sy ${pkgs} ;;
        pkg)    hpkg_vrun sudo pkg          install --yes   ${pkgs} ;;
        npm)    hpkg_vrun sudo npm          install -g      ${pkgs} ;;
        go)     hpkg_vrun      go           install         ${pkgs} ;;
        gem)    hpkg_vrun sudo gem          install --no-user-install -n /usr/bin ${pkgs} ;;
        pip3)   hpkg_vrun sudo pip3          install ${pkgs};;
        apk)    hpkg_vrun sudo apk          add ${pkgs};;
        *)      hpkg_error "Unsupported package manager.";;
    esac
}
hpkg_remove() {
    local pkgs="`hpkg_select "$@"`"
    if test ! -n "${pkgs}";then
        hpkg_error "Unsupported platform." >&2
        return 1
    fi
    case "${PACKAGE_MANAGER}" in
        dpkg)   sudo apt-get remove ${pkgs} ||  true    ;;
        rpm)    : sudo yum -y remove ${pkgs}         ;;
        xbps)   sudo xbps-remove ${pkgs} || true      ;;
        pacman) : sudo pacman --noconfirm -Sy ${pkgs} ;;
        pkg)    : sudo pkg uninstall --yes ${pkgs}      ;;
        npm)    : sudo npm uninstall -g ${pkgs}         ;;
        go)     : go get ${pkgs}                      ;;
        *)      hpkg_error "Unsupported package manager.";;
    esac
}
hpkg_service_void() {
    local ops="$1" s= sleep=; shift
    hpkg_select_var "$@"
    if test ! -n "${HPKG_PACKAGES}"; then
        hpkg_error "Unsupported platform." >&2
        return 1
    fi
    for s in ${HPKG_PACKAGES}; do
        local d="/etc/sv/${s}"
        local l="/etc/runit/runsvdir/default/${s}"
        case "${ops}" in
            *E*) echo "${SCRNAME}: Enabling ${s} ..." >&2
                 if test ! -e "${d}"; then
                     hpkg_error "${s}: Service not found."
                     return 1
                 elif test ! -e "${l}"; then
                     sudo ln -s "${d}" "${l}"
                     local sleep=2
                 fi
                 ;;
            *X*) if test -e "${l}"; then
                     echo "${SCRNAME}: Shutting down ${s} ..." >&2
                     sudo sv down   "${s}" >&2 || true
                     echo "${SCRNAME}: Deleting ${s} service ..." >&2
                     sudo rm -f "/etc/runit/runsvdir/default/${s}"
                 fi
                 ;;
        esac
    done
    if test -n "${sleep}"; then
        sleep "${sleep}"
    fi
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *R*) echo "${SCRNAME}: Restarting ${s} ..." >&2
                 sudo sv down   "${s}" >&2 || true
                 sudo sv up     "${s}" >&2
                 ;;
            *O*) echo "${SCRNAME}: Shutting down ${s} ..." >&2
                 sudo sv down   "${s}" >&2 || true
                 ;;
        esac
    done
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *V*) sudo sv status "${s}"  >&2 || true;;
        esac
    done
}
hpkg_service_freebsd() {
    local ops="$1" s=; shift
    hpkg_select_var "$@"
    if test ! -n "${HPKG_PACKAGES}"; then
        hpkg_error "Unsupported platform." >&2
        return 1
    fi
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *E*) echo "${SCRNAME}: Enabling ${s} ..." >&2
                 sudo service "${s}" enable
                 ;;
            *X*) echo "${SCRNAME}: Shutting down ${s} ..." >&2
                 sudo service "${s}" stop >&2 || true
                 echo "${SCRNAME}: Disabling ${s} service ..." >&2
                 sudo service "${s}" disable
                 ;;
        esac
    done
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *R*) echo "${SCRNAME}: Restarting ${s} ..." >&2
                 sudo service "${s}" stop  >&2 || true
                 sudo service "${s}" start >&2
                 ;;
            *O*) echo "${SCRNAME}: Shutting down ${s} ..." >&2
                 sudo service "${s}" stop >&2 || true
                 ;;
        esac
    done
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *V*) sudo service "${s}" status >&2 || true;;
        esac
    done
}
hpkg_service_rocky() {
    local ops="$1" s=; shift
    hpkg_select_var "$@"
    if test ! -n "${HPKG_PACKAGES}"; then
        hpkg_error "Unsupported platform." >&2
        return 1
    fi
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *E*) echo "${SCRNAME}: Enabling ${s} ..." >&2
                 sudo systemctl enable "${s}"
                 ;;
            *X*) echo "${SCRNAME}: Shutting down ${s} ..." >&2
                 sudo systemctl stop "${s}" >&2 || true
                 echo "${SCRNAME}: Disabling ${s} service ..." >&2
                 sudo systemctl disable "${s}"
                 ;;
        esac
    done
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *R*) echo "${SCRNAME}: Restarting ${s} ..." >&2
                 sudo systemctl stop "${s}" >&2 || true
                 sudo systemctl start "${s}" >&2
                 ;;
            *O*) echo "${SCRNAME}: Shutting down ${s} ..." >&2
                 sudo systemctl stop "${s}" >&2 || true
                 ;;
        esac
    done
    for s in ${HPKG_PACKAGES}; do
        case "${ops}" in
            *V*) sudo systemctl status "${s}" >&2 || true;;
        esac
    done
}


hpkg_check() {
    local arg= ret=
    for arg in "$@";do
        case "${arg}" in
            @${DISTRO_ID})       local ret=0;;
            %${PACKAGE_MANAGER}) local ret=0;;
        esac
    done
    return "${ret:-1}"
}

hpkg_vrun() {
    if test -n "${HPKG_VERBOSE}";then
        echo "${SCRNAME}: Running: $*" >&2
    fi
    "$@"
}


## -----------------------------------------------------------------------------
SCRNAME="${SCRNAME:-`basename "$0"`}"
hpkg_calc_variables
if test @"${SCRNAME}" = @"hpkg";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hpkg "$@"
            ;;
    esac
fi
