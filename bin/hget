#h: Usage: $0 [-d DIR] URL [NAME]
#h:
#h: Download file to a temporary directory and print name. If the name can't
#h: be infered from the URL then you can specify a name.
hget() {
    ##
    local tmp=/tmp OPTIND optopt=
    while getopts "d:" optopt;do # OPTARG
        case $optopt in
            d)  local tmp="${OPTARG}";;
            \?) return 1;;
        esac
    done
    shift $(( $OPTIND - 1 ))
    ## 
    local url="${1}"
    case "${url}" in
        *://*) local fil=${tmp}/"${2:-`basename "${url}"`}"
               if test -f "${fil}";then
                   true
               elif which wget >/dev/null 2>&1;then
                   wget --no-check-certificate -O "${fil}.tmp" "${url}" >&2
                   mv "${fil}.tmp" "${fil}"
               elif which curl >/dev/null 2>&1;then
                   curl -L -o "${fil}.tmp" "${url}"
                   mv "${fil}.tmp" "${fil}"
               else
                   echo "${SCRNAME} [E]: Please install 'curl' or 'wget'." >&2
                   return 1
               fi;;
        *)     local fil="${url}"
               if test ! -f "${fil}";then
                   echo "${SCRNAME} [E]: The file ${fil} does not exist." >&2
                   return 1
               fi
               ;;
    esac
    echo "${fil}"
}
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"hget";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hget "$@"
            ;;
    esac
fi
