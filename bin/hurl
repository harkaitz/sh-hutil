##:
#h: Usage:
#h:
#h: URL encoding and decoding from the terminal.
#h:
#h: $0 encode TEXT...
#h: $0 decode TEXT...
#h: $0 encode-i < FILE
#h: $0 decode-i < FILE
#h:
#h: $0 get VAR URL
##:
hurl() {
    local cmd="$1"
    shift
    case "${cmd}" in
        encode)   printf '%s\n' "$*" | hurl encode-i ;;
        decode)   printf '%s\n' "$*" | hurl decode-i ;;
        encode-i) hurl_encode_i                      ;;
        decode-i) hurl_decode_i                      ;;
        get)      hurl_get "$@"                      ;;
        *)        echo "hurl: error: " >&2; return 1 ;;
    esac
}
## -----------------------------------------------------------------------------
hurl_encode_i() {
    sed '
                s/ /%20/g
                s/!/%21/g
                s/"/%22/g
                s/#/%23/g
                s/\$/%24/g
                s/\&/%26/g
                s/'\''/%27/g
                s/(/%28/g
                s/)/%29/g
                s/:/%3A/g
            '
}
hurl_decode_i() {
    awk -v RS='%[0-9a-fA-F]{2}' '
                RT{
                   sub("%","0x",RT)
                   RT=sprintf("%c",strtonum(RT))
                }
                {
                   gsub(/\+/," ")
                   printf "%s", $0 RT
                }
            '
}
hurl_get() {
    local v="$1" u="$2"
    printf '%s\n' "${u}"  \
        | cut -d '?' -f 2 \
        | tr '&' '\n'     \
        | awk -F '=' -v v="${v}" '$1 == v {print $2}' \
        | hurl_decode_i
}
## -----------------------------------------------------------------------------
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"hurl";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hurl "$@"
            ;;
    esac
fi
