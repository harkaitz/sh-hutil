#h: Usage:
#h:
#h: $0 encode TEXT...
#h: $0 decode TEXT...
#h: $0 encode-i < FILE
#h: $0 decode-i < FILE

hurl() {
    local cmd="$1"
    shift
    case "${cmd}" in
        encode)
            echo "$*" | hurl encode-i
            ;;
        decode)
            echo "$*" | hurl decode-i
            ;;
        encode-i)
            sed '
                s/ /%20/g
                s/!/%21/g
                s/"/%22/g
                s/#/%23/g
                s/\$/%24/g
                s/\&/%26/g
                s/'\''/%27/g
                s/(/%28/g
                s/)/%29/g
                s/:/%3A/g
            '
            ;;
        decode-i)
            awk -v RS='%[0-9a-fA-F]{2}' '
                RT{
                   sub("%","0x",RT)
                   RT=sprintf("%c",strtonum(RT))
                }
                {
                   gsub(/\+/," ")
                   printf "%s", $0 RT
                }
            '
            ;;
        *)  echo "${SCRNAME} [E]: " >&2
            return 1;;
    esac
}
## -----------------------------------------------------------------------------
SCRNAME="`basename "$0"`"
if test @"${SCRNAME}" = @"hurl";then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hurl "$@"
            ;;
    esac
fi
