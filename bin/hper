##:
#h: Usage: $0 [-vp] VAR[=VAL] ...
#h:
#h: Save and restore variables in permanent memory. 
hper() {
    local OPTIND optopt opt_p= varval= var= val=
    ## Parse command line arguments.
    while getopts "vp" optopt; do
        case $optopt in
            v)  printf '%-20s : %s\n' HPERDIR "${HPERDIR}";;
            p)  local opt_p=y;;
            \?) return 1;;
        esac
    done
    shift $(( $OPTIND - 1 ))
    ## For each variables.
    mkdir -p "${HPERDIR}"
    for varval in "$@"; do
        case "${varval}" in
            *=*)
                var="`printf '%s\n' "${varval}" | sed    's|=.*||'      `"
                val="`printf '%s\n' "${varval}" | sed -n 's|^[^=]*=||p' `"
                export "${var}=${val}"
                if test -n "${val}"; then
                    printf '%s\n' "${val}" > "${HPERDIR}/${var}.txt"
                else
                    rm "${HPERDIR}/${var}.txt"
                fi
                ;;
            *)
                var="$1"
                if test -e "${HPERDIR}/${var}.txt"; then
                    export "${var}=`cat "${HPERDIR}/${var}.txt"`"
                    if test -n "${opt_p}"; then
                        cat "${HPERDIR}/${var}.txt"
                    fi
                else
                    export "${var}="
                fi
                ;;
        esac
    done
}
SCRNAME="`basename "$0"`"
HPERDIR="${HPERDIR:-${HOME}/.hper/${SCRNAME}}"
if test @"${SCRNAME}" = @"hper"; then
    case "${1}" in
        ''|-h|--help)
            sed -n 's/^ *#h: \{0,1\}//p' "$0" | sed "s|\\\$0|${SCRNAME}|g"
            echo ""
            sed -n 's/^ *#l: \{0,2\}//p' "$0"
            ;;
        *)
            hper -p "$@"
            ;;
    esac
fi
